# --- Frontend (Vite/React) ---
# Este app é SOMENTE frontend. As chamadas de IA vivem no backend (apps/apis).

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# --- Proxy BFF para o backend NestJS (lido pelo vite.config.ts, lado servidor) ---
# Alvo da API. As chamadas /api/* do frontend são encaminhadas para cá.
API_TARGET=http://localhost:3001
# Segredo injetado pelo proxy nas requisições à API. NUNCA vai ao bundle/browser.
# DEVE ser igual ao INTERNAL_API_KEY do apps/apis/.env.
INTERNAL_API_KEY=troque-por-um-segredo-forte
