# Porta do backend NestJS
API_PORT=3001

# Origem(ns) da aplicação web autorizada(s) a chamar a API (CORS allowlist).
# Separe por vírgula para múltiplas origens.
WEB_ORIGIN=http://localhost:3000

# Segredo compartilhado entre o proxy BFF da web e a API.
# DEVE ser igual ao INTERNAL_API_KEY do apps/web/.env. Nunca exposto ao browser.
INTERNAL_API_KEY=troque-por-um-segredo-forte

# Qwen Cloud (DashScope) — OpenAI-compatible
DASHSCOPE_API_KEY=sk-sua-chave-dashscope
DASHSCOPE_API_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Modelo usado pelos agentes Coletor e Classificador
QWEN_MODEL=qwen3.6-flash
# Opcional: modelos de fallback (separados por vírgula) p/ casos de 503
# QWEN_MODEL_FALLBACKS=qwen3.7-plus
