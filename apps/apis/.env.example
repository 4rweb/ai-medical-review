# Porta do backend NestJS
API_PORT=3001

# Origem(ns) da aplicação web autorizada(s) a chamar a API (CORS allowlist).
# Separe por vírgula para múltiplas origens.
WEB_ORIGIN=http://localhost:3000

# Segredo compartilhado entre o proxy BFF da web e a API.
# DEVE ser igual ao INTERNAL_API_KEY do apps/web/.env. Nunca exposto ao browser.
INTERNAL_API_KEY=troque-por-um-segredo-forte

# Banco de dados — ApsaraDB (RDS PostgreSQL). Se ausente, o app degrada para
# armazenamento em memória (fila não persiste; auditoria vai só para o log).
DATABASE_URL=postgresql://user:senha@host:5432/medical_review

# Qwen Cloud (DashScope) — OpenAI-compatible
DASHSCOPE_API_KEY=sk-sua-chave-dashscope
DASHSCOPE_API_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Modelo usado pelos agentes
QWEN_MODEL=qwen3.6-flash

# Transcrição de áudio (ASR dedicado). Idioma em código ISO (pt, en, es...).
QWEN_ASR_MODEL=qwen3-asr-flash
QWEN_ASR_LANGUAGE=pt

# Overrides opcionais por agente; quando ausentes, usam QWEN_MODEL.
# QWEN_COLLECTOR_MODEL=qwen3.6-flash
# QWEN_CLASSIFIER_MODEL=qwen3.6-flash

# Servidor MCP clínico. O backend usa MCP primeiro e cai para execução local
# determinística se o host estiver indisponível.
MCP_ENABLED=true
MCP_SERVER_URL=http://127.0.0.1:3002/mcp
MCP_TOOL_TIMEOUT_MS=2500
MCP_FAILURE_COOLDOWN_MS=15000
